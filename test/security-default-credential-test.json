{
  "openapi": "3.0.3",
  "info": {
    "title": "Security Default Credential Test API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "components": {
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "defaultCredential": "basic-user-pass"
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "x-defaultCredential": "bearer-token"
      },
      "ApiKeyHeaderAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY",
        "defaultCredential": "header-key"
      },
      "ApiKeyQueryAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "x-defaultCredential": "query-key"
      }
    }
  },
  "paths": {
    "/hello": {
      "get": {
        "summary": "Get hello",
        "operationId": "getHello",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  }
}
